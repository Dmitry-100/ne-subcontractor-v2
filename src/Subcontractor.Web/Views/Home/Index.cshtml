@{
    ViewData["Title"] = "Дашборд";
    var dashboardApiEndpoint = Url.Content("~/api/dashboard/summary");
    var analyticsApiEndpoint = Url.Content("~/api/analytics/kpi");
}

@section Head {
    <link rel="stylesheet" href="~/css/dashboard-ibm.css" asp-append-version="true" />
}

<section class="dashboard dashboard--ibm shell-panel"
         data-dashboard-module
         data-api-endpoint="@dashboardApiEndpoint"
         data-analytics-endpoint="@analyticsApiEndpoint">
    <header class="shell-panel__header">
        <h1>Управление субподрядом</h1>
        <p>Сводный экран системы: статусы по основным сущностям, контроль сроков, задачи пользователей и показатели процесса.</p>
    </header>

    <div class="dashboard-toolbar">
        <button type="button" class="dashboard-refresh" data-dashboard-refresh>Обновить дашборд</button>
        <a class="registry-api-link" href="@dashboardApiEndpoint" target="_blank" rel="noopener">Открыть API</a>
    </div>

    <p class="dashboard-status" data-dashboard-status>Загрузка дашборда...</p>

    <div class="dashboard-metrics">
        <article class="dashboard-metric">
            <h2>Проекты</h2>
            <p data-dashboard-counter="projectsTotal">0</p>
        </article>
        <article class="dashboard-metric">
            <h2>Лоты</h2>
            <p data-dashboard-counter="lotsTotal">0</p>
        </article>
        <article class="dashboard-metric">
            <h2>Процедуры</h2>
            <p data-dashboard-counter="proceduresTotal">0</p>
        </article>
        <article class="dashboard-metric">
            <h2>Договоры</h2>
            <p data-dashboard-counter="contractsTotal">0</p>
        </article>
    </div>

    <div class="dashboard-layout">
        <div class="dashboard-main">
            <section class="dashboard-panel dashboard-panel--statuses">
                <h2>Структура статусов</h2>
                <div class="dashboard-status-columns">
                    <div>
                        <h3>Лоты</h3>
                        <ul class="dashboard-status-list" data-dashboard-status-list="lots"></ul>
                    </div>
                    <div>
                        <h3>Процедуры</h3>
                        <ul class="dashboard-status-list" data-dashboard-status-list="procedures"></ul>
                    </div>
                    <div>
                        <h3>Договоры</h3>
                        <ul class="dashboard-status-list" data-dashboard-status-list="contracts"></ul>
                    </div>
                </div>

                <h3 class="dashboard-kpi-inline-title">Базовые показатели</h3>
                <div class="dashboard-kpi-infographics dashboard-kpi-infographics--status">
                    <article class="dashboard-kpi-card">
                        <div class="dashboard-kpi-ring" data-dashboard-kpi-ring="milestoneCompletionRatePercent">
                            <strong data-dashboard-kpi="milestoneCompletionRatePercent">н/д</strong>
                        </div>
                        <p>Доля завершённых этапов</p>
                    </article>
                    <article class="dashboard-kpi-card">
                        <div class="dashboard-kpi-ring" data-dashboard-kpi-ring="procedureCompletionRatePercent">
                            <strong data-dashboard-kpi="procedureCompletionRatePercent">н/д</strong>
                        </div>
                        <p>Доля завершённых процедур</p>
                    </article>
                    <article class="dashboard-kpi-card">
                        <div class="dashboard-kpi-ring" data-dashboard-kpi-ring="contractClosureRatePercent">
                            <strong data-dashboard-kpi="contractClosureRatePercent">н/д</strong>
                        </div>
                        <p>Доля закрытых договоров</p>
                    </article>
                </div>
            </section>

            <section class="dashboard-panel dashboard-panel--analytics">
                <h2>Аналитика показателей</h2>
                <p class="dashboard-analytics-status" data-dashboard-analytics-status>Аналитический контур загружается...</p>

                <div class="dashboard-analytics-infographics">
                    <article class="dashboard-analytics-mini dashboard-analytics-mini--lot">
                        <p class="dashboard-analytics-mini__label">Воронка лотов</p>
                        <div class="dashboard-analytics-funnel">
                            <p><span>Черновик</span><strong data-dashboard-analytics-highlight="lotDraft">0</strong></p>
                            <p><span>В закупке</span><strong data-dashboard-analytics-highlight="lotInProcurement">0</strong></p>
                            <p><span>Законтрактовано</span><strong data-dashboard-analytics-highlight="lotContracted">0</strong></p>
                        </div>
                    </article>

                    <article class="dashboard-analytics-mini">
                        <p class="dashboard-analytics-mini__label">Перегрузка подрядчиков</p>
                        <p class="dashboard-analytics-mini__value">
                            <strong data-dashboard-analytics-highlight="overloadShare">0%</strong>
                            <span data-dashboard-analytics-highlight="contractorLoadMeta">0 из 0</span>
                        </p>
                        <div class="dashboard-analytics-mini__bar" aria-hidden="true">
                            <span data-dashboard-analytics-bar="overloadShare"></span>
                        </div>
                    </article>

                    <article class="dashboard-analytics-mini">
                        <p class="dashboard-analytics-mini__label">Средняя загрузка</p>
                        <p class="dashboard-analytics-mini__value"><strong data-dashboard-analytics-highlight="averageLoad">н/д</strong></p>
                        <div class="dashboard-analytics-mini__bar" aria-hidden="true">
                            <span data-dashboard-analytics-bar="averageLoad"></span>
                        </div>
                    </article>

                    <article class="dashboard-analytics-mini">
                        <p class="dashboard-analytics-mini__label">Средний рейтинг</p>
                        <p class="dashboard-analytics-mini__value"><strong data-dashboard-analytics-highlight="averageRating">н/д</strong></p>
                        <div class="dashboard-analytics-mini__bar" aria-hidden="true">
                            <span data-dashboard-analytics-bar="averageRating"></span>
                        </div>
                    </article>

                    <article class="dashboard-analytics-mini">
                        <p class="dashboard-analytics-mini__label">MDR покрытие</p>
                        <p class="dashboard-analytics-mini__value"><strong data-dashboard-analytics-highlight="mdrCoverage">н/д</strong></p>
                        <div class="dashboard-analytics-mini__bar" aria-hidden="true">
                            <span data-dashboard-analytics-bar="mdrCoverage"></span>
                        </div>
                    </article>

                    <article class="dashboard-analytics-mini">
                        <p class="dashboard-analytics-mini__label">Доля субподряда</p>
                        <p class="dashboard-analytics-mini__value"><strong data-dashboard-analytics-highlight="subcontractingShare">н/д</strong></p>
                        <div class="dashboard-analytics-mini__bar" aria-hidden="true">
                            <span data-dashboard-analytics-bar="subcontractingShare"></span>
                        </div>
                    </article>

                    <article class="dashboard-analytics-mini dashboard-analytics-mini--split">
                        <p class="dashboard-analytics-mini__label">SLA контур</p>
                        <div class="dashboard-analytics-split">
                            <p><span>Предупреждения</span><strong data-dashboard-analytics-highlight="slaWarnings">0</strong></p>
                            <p><span>Просрочки</span><strong data-dashboard-analytics-highlight="slaOverdue">0</strong></p>
                        </div>
                        <div class="dashboard-analytics-mini__bar" aria-hidden="true">
                            <span data-dashboard-analytics-bar="slaOverdueShare"></span>
                        </div>
                    </article>

                    <article class="dashboard-analytics-mini dashboard-analytics-mini--split">
                        <p class="dashboard-analytics-mini__label">Контрактование</p>
                        <div class="dashboard-analytics-split dashboard-analytics-split--money">
                            <p><span>Действует</span><strong data-dashboard-analytics-highlight="contractingActiveAmount">0</strong></p>
                            <p><span>Закрыто</span><strong data-dashboard-analytics-highlight="contractingClosedAmount">0</strong></p>
                        </div>
                        <div class="dashboard-analytics-mini__bar" aria-hidden="true">
                            <span data-dashboard-analytics-bar="contractingClosedShare"></span>
                        </div>
                    </article>
                </div>

                <details class="dashboard-disclosure dashboard-disclosure--analytics">
                    <summary>
                        <span>Рейтинг подрядчиков</span>
                        <span class="dashboard-disclosure__hint">развернуть</span>
                    </summary>
                    <div class="dashboard-disclosure__content">
                        <h3>Топ подрядчиков</h3>
                        <ul class="dashboard-top-contractors" data-dashboard-top-contractors></ul>
                    </div>
                </details>
            </section>
        </div>

        <aside class="dashboard-rail">
            <section class="dashboard-panel dashboard-panel--overdue">
                <h2>Контроль просрочек</h2>
                <div class="dashboard-overdue-cards">
                    <article class="dashboard-overdue-card dashboard-overdue-card--danger">
                        <p class="dashboard-overdue-card__label">Процедуры с просрочкой</p>
                        <p class="dashboard-overdue-card__value">
                            <strong data-dashboard-overdue="proceduresCount">0</strong>
                            <span data-dashboard-overdue-rate="procedures">0%</span>
                        </p>
                        <p class="dashboard-overdue-card__hint" data-dashboard-overdue-context="procedures">из 0 процедур</p>
                        <div class="dashboard-overdue-card__bar" aria-hidden="true">
                            <span data-dashboard-overdue-bar="procedures"></span>
                        </div>
                    </article>

                    <article class="dashboard-overdue-card dashboard-overdue-card--warning">
                        <p class="dashboard-overdue-card__label">Договоры с просрочкой</p>
                        <p class="dashboard-overdue-card__value">
                            <strong data-dashboard-overdue="contractsCount">0</strong>
                            <span data-dashboard-overdue-rate="contracts">0%</span>
                        </p>
                        <p class="dashboard-overdue-card__hint" data-dashboard-overdue-context="contracts">из 0 договоров</p>
                        <div class="dashboard-overdue-card__bar" aria-hidden="true">
                            <span data-dashboard-overdue-bar="contracts"></span>
                        </div>
                    </article>

                    <article class="dashboard-overdue-card">
                        <p class="dashboard-overdue-card__label">Просроченные этапы</p>
                        <p class="dashboard-overdue-card__value">
                            <strong data-dashboard-overdue="milestonesCount">0</strong>
                            <span data-dashboard-overdue-rate="milestones">0%</span>
                        </p>
                        <p class="dashboard-overdue-card__hint" data-dashboard-overdue-context="milestones">доля среди всех просрочек</p>
                        <div class="dashboard-overdue-card__bar" aria-hidden="true">
                            <span data-dashboard-overdue-bar="milestones"></span>
                        </div>
                    </article>
                </div>
            </section>
        </aside>
    </div>

    <details class="dashboard-disclosure dashboard-disclosure--import dashboard-panel dashboard-panel--import">
        <summary>
            <span>Импортный конвейер</span>
            <span class="dashboard-disclosure__hint">развернуть</span>
        </summary>
        <div class="dashboard-disclosure__content">
            <ul class="dashboard-import-list">
                <li>Исходные данные: загружено в очередь <strong data-dashboard-import="sourceUploadedCount">0</strong></li>
                <li>Исходные данные: в обработке <strong data-dashboard-import="sourceProcessingCount">0</strong></li>
                <li>Исходные данные: готово к лотированию <strong data-dashboard-import="sourceReadyForLottingCount">0</strong></li>
                <li>Исходные данные: с ошибками валидации <strong data-dashboard-import="sourceValidatedWithErrorsCount">0</strong></li>
                <li>Исходные данные: ошибка обработки <strong data-dashboard-import="sourceFailedCount">0</strong></li>
                <li>Исходные данные: отклонено <strong data-dashboard-import="sourceRejectedCount">0</strong></li>
                <li>Исходные данные: невалидных строк <strong data-dashboard-import="sourceInvalidRowsCount">0</strong></li>
                <li>XML-очередь: получено <strong data-dashboard-import="xmlReceivedCount">0</strong></li>
                <li>XML-очередь: в обработке <strong data-dashboard-import="xmlProcessingCount">0</strong></li>
                <li>XML-очередь: обработано <strong data-dashboard-import="xmlCompletedCount">0</strong></li>
                <li>XML-очередь: ошибка <strong data-dashboard-import="xmlFailedCount">0</strong></li>
                <li>XML-очередь: повторно поставлено в очередь <strong data-dashboard-import="xmlRetriedPendingCount">0</strong></li>
                <li>Трассировка: групп в apply-операциях <strong data-dashboard-import="traceAppliedGroupsCount">0</strong></li>
                <li>Трассировка: успешно создано групп <strong data-dashboard-import="traceCreatedGroupsCount">0</strong></li>
                <li>Трассировка: пропущено групп <strong data-dashboard-import="traceSkippedGroupsCount">0</strong></li>
                <li>Трассировка: создано уникальных лотов <strong data-dashboard-import="traceCreatedLotsCount">0</strong></li>
            </ul>
        </div>
    </details>

    <details class="dashboard-disclosure dashboard-disclosure--tasks dashboard-panel dashboard-panel--tasks">
        <summary>
            <span>Мои задачи</span>
            <span class="dashboard-disclosure__hint">развернуть</span>
        </summary>
        <div class="dashboard-disclosure__content">
            <ul class="dashboard-tasks" data-dashboard-tasks></ul>
        </div>
    </details>

    <details class="dashboard-disclosure dashboard-disclosure--links dashboard-panel dashboard-panel--links">
        <summary>
            <span>Быстрая навигация</span>
            <span class="dashboard-disclosure__hint">развернуть</span>
        </summary>
        <div class="dashboard-disclosure__content">
            <p class="dashboard-links-intro">Откройте нужный раздел для работы с реестрами, процессами и сервисными модулями.</p>
            <div class="dashboard-grid">
        <article class="card">
            <h2>Проекты</h2>
            <p>Реестр проектов с созданием, редактированием и просмотром ответственных лиц.</p>
            <a asp-controller="Home" asp-action="Projects" class="card-link">Открыть проекты</a>
        </article>
        <article class="card">
            <h2>Лоты</h2>
            <p>Реестр лотов с переходами статусов и журналом изменений.</p>
            <a asp-controller="Home" asp-action="Lots" class="card-link">Открыть лоты</a>
        </article>
        <article class="card">
            <h2>Процедуры</h2>
            <p>Закупочные процедуры с маршрутами статусов и подбором кандидатов.</p>
            <a asp-controller="Home" asp-action="Procedures" class="card-link">Открыть процедуры</a>
        </article>
        <article class="card">
            <h2>Договоры</h2>
            <p>Договоры с жизненным циклом, этапами исполнения и блоком мониторинга.</p>
            <a asp-controller="Home" asp-action="Contracts" class="card-link">Открыть договоры</a>
        </article>
        <article class="card">
            <h2>Подрядчики</h2>
            <p>Рейтинг подрядчиков, экспертная оценка и аналитика изменений.</p>
            <a asp-controller="Home" asp-action="Contractors" class="card-link">Открыть подрядчиков</a>
        </article>
        <article class="card">
            <h2>Администрирование</h2>
            <p>Назначение ролей пользователям и ведение справочников системы.</p>
            <a asp-controller="Home" asp-action="Admin" class="card-link">Открыть администрирование</a>
        </article>
        <article class="card">
            <h2>Импорт</h2>
            <p>Загрузка исходных данных, проверка пакетов и трассировка ошибок.</p>
            <a asp-controller="Home" asp-action="Imports" class="card-link">Открыть импорт</a>
        </article>
        <article class="card">
            <h2>Контроль сроков</h2>
            <p>Правила SLA, нарушения сроков, причины отклонений и запуск мониторинга.</p>
            <a asp-controller="Home" asp-action="Sla" class="card-link">Открыть контроль сроков</a>
        </article>
            </div>
        </div>
    </details>
</section>

@section Scripts {
    <script src="~/js/bundles/dashboard-page.bundle.js" asp-append-version="true"></script>
}
