{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=SubcontractorV2;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Security": {
    "BootstrapAdminLogins": []
  },
  "SlaMonitoring": {
    "DefaultWarningDaysBeforeDue": 2,
    "WorkerPollingIntervalMinutes": 15,
    "WorkerEnabled": true
  },
  "ContractorRating": {
    "WorkerPollingIntervalMinutes": 240,
    "WorkerEnabled": true,
    "AutoRecalculateActiveOnly": true
  },
  "Smtp": {
    "Enabled": false,
    "DryRun": true,
    "Host": "",
    "Port": 25,
    "EnableSsl": false,
    "Username": "",
    "Password": "",
    "FromAddress": "no-reply@subcontractor.local",
    "FromDisplayName": "Subcontractor SLA Bot"
  },
  "UiAssets": {
    "DevExpress": {
      "UseLocal": false,
      "UseLocalFallbackWhenCdnFails": true,
      "Version": "24.1.6",
      "CdnBaseUrl": "https://cdn3.devexpress.com/jslib",
      "FallbackCdnBaseUrl": "https://cdn.jsdelivr.net/npm/devextreme-dist@{version}",
      "JqueryCdnUrl": "https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js",
      "JqueryFallbackCdnUrl": "https://code.jquery.com/jquery-3.7.1.min.js",
      "LocalBasePath": "/lib/devexpress/24.1.6"
    },
    "SheetJs": {
      "UseLocal": false,
      "UseLocalFallbackWhenCdnFails": true,
      "Version": "0.18.5",
      "CdnUrl": "https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js",
      "FallbackCdnUrl": "https://unpkg.com/xlsx@0.18.5/dist/xlsx.full.min.js",
      "LocalPath": "/lib/xlsx/0.18.5/xlsx.full.min.js"
    }
  },
  "DemoSeed": {
    "EnableApi": false,
    "EnableStartupSeed": false,
    "ContractsPrefix": "SMOKE-READONLY"
  },
  "WebHostTopology": {
    "EnableEmbeddedWorkers": false,
    "EnableDemoSeedWorker": false
  },
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
